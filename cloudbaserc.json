{
  "version": "2.0",
  "envId": "yangliuqing-d5grq63943e36590b",
  "framework": {
    "name": "school-rebellion-game",
    "plugins": {
      "client": {
        "use": "@cloudbase/framework-plugin-website",
        "inputs": {
          "buildCommand": "npm run build",
          "outputPath": "dist",
          "cloudPath": "/yangliuqing88"
        }
      },
      "websocket": {
        "use": "@cloudbase/framework-plugin-function",
        "inputs": {
          "functionRootPath": "cloudfunctions",
          "functions": [
            {
              "name": "websocket-server",
              "timeout": 60,
              "runtime": "Nodejs18.15",
              "handler": "index.main",
              "envVariables": {
                "PORT": "9000"
              }
            }
          ]
        }
      }
    }
  }
}
